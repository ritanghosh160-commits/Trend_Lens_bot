<!DOCTYPE html><!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>ViralScript AI | Global Creator Tool</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">

    <style>
        @import url('https://fonts.googleapis.com/css2?family=Inter:wght@300;400;600;700&display=swap');
        body {
            font-family: 'Inter', sans-serif;
            background-color: #0f172a;
            color: white;
        }
        .glass {
            background: rgba(30, 41, 59, 0.7);
            backdrop-filter: blur(10px);
            border: 1px solid rgba(255,255,255,0.1);
        }
        .gradient-text {
            background: linear-gradient(90deg, #38bdf8, #818cf8);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
        }
    </style>
</head>

<body class="p-4 md:p-10">

<div class="max-w-4xl mx-auto text-center mb-10">
    <h1 class="text-4xl md:text-6xl font-bold mb-4 gradient-text">ViralScript AI</h1>
    <p class="text-slate-400 text-lg">Stop guessing. Create hooks that capture the world.</p>

    <div class="mt-6 p-2 border border-dashed border-slate-700 text-xs text-slate-500 rounded">
        ADVERTISEMENT SPACE (Google AdSense)
    </div>
</div>

<main class="max-w-4xl mx-auto grid gap-8">

    <!-- Hook Generator -->
    <section class="glass p-6 rounded-2xl shadow-xl">
        <h2 class="text-xl font-semibold mb-4">
            <i class="fas fa-magic mr-2 text-sky-400"></i> Generate High-Retention Hooks
        </h2>

        <div class="flex flex-col gap-4">
            <input id="topicInput" type="text"
                   placeholder="Enter topic (e.g. Minecraft, Finance, Life Hacks)..."
                   class="w-full bg-slate-800 border border-slate-700 p-4 rounded-lg focus:outline-none focus:ring-2 focus:ring-sky-500">

            <div class="flex gap-2">
                <select id="toneSelect"
                        class="bg-slate-800 border border-slate-700 p-4 rounded-lg flex-1">
                    <option value="curiosity">Curiosity</option>
                    <option value="fear">Urgency</option>
                    <option value="value">High Value</option>
                </select>

                <button onclick="generateHooks()"
                        class="bg-sky-500 hover:bg-sky-600 px-8 py-4 rounded-lg font-bold">
                    Generate ⚡
                </button>
            </div>
        </div>
    </section>

    <!-- Result -->
    <section id="resultSection" class="hidden glass p-6 rounded-2xl">
        <h2 class="text-lg font-semibold mb-4 text-sky-400">Your Viral Hooks:</h2>
        <div id="hookList" class="space-y-3"></div>
    </section>

    <!-- Tools -->
    <div class="grid md:grid-cols-2 gap-6">

        <!-- Scratchpad -->
        <section class="glass p-6 rounded-2xl">
            <h2 class="text-lg font-semibold mb-4">
                <i class="fas fa-edit mr-2 text-sky-400"></i> Script Scratchpad
            </h2>

            <textarea id="scratchpad"
                      class="w-full h-48 bg-slate-800/50 p-4 rounded-lg text-sm border border-slate-700"
                      placeholder="Write your script..."></textarea>
        </section>

        <!-- Checklist -->
        <section class="glass p-6 rounded-2xl">
            <h2 class="text-lg font-semibold mb-4">
                <i class="fas fa-check-circle mr-2 text-green-400"></i> Viral Checklist
            </h2>

            <div class="space-y-2 text-sm text-slate-300">
                <label><input type="checkbox"> Hook in first 3 sec?</label><br>
                <label><input type="checkbox"> Subtitles ready?</label><br>
                <label><input type="checkbox"> Good audio/video?</label><br>
                <label><input type="checkbox"> CTA included?</label>
            </div>
        </section>

    </div>
</main>

<footer class="max-w-4xl mx-auto mt-20 text-center text-slate-500 text-sm border-t border-slate-800 pt-6">
    © 2026 ViralScript AI
</footer>

<script>
    // Auto Save
    const pad = document.getElementById('scratchpad');
    pad.value = localStorage.getItem('userScript') || '';

    pad.addEventListener('input', () => {
        localStorage.setItem('userScript', pad.value);
    });

    function generateHooks() {
        const topic = document.getElementById('topicInput').value.trim();
        const tone = document.getElementById('toneSelect').value;
        const list = document.getElementById('hookList');
        const section = document.getElementById('resultSection');

        if (!topic) {
            alert("Enter topic first!");
            return;
        }

        section.classList.remove('hidden');

        list.innerHTML = `<div class="text-slate-400 animate-pulse">Generating...</div>`;

        setTimeout(() => {
            let hooks = [];

            if (tone === 'curiosity') {
                hooks = [
                    `This ${topic} trick will blow your mind.`,
                    `Wait... no one told you this about ${topic}?`,
                    `This is why everyone is talking about ${topic}.`
                ];
            } else if (tone === 'fear') {
                hooks = [
                    `Stop doing this in ${topic} right now!`,
                    `You're ruining your ${topic} without knowing.`,
                    `This ${topic} mistake can cost you everything.`
                ];
            } else {
                hooks = [
                    `How to master ${topic} in 60 seconds.`,
                    `3 powerful ${topic} tips you must know.`,
                    `Beginner guide to ${topic} (2026).`
                ];
            }

            list.innerHTML = hooks.map(h => `
                <div onclick="copyHook('${h}')"
                     class="bg-slate-800 p-4 rounded-lg cursor-pointer hover:border-sky-500 border border-slate-700">
                    ${h}
                </div>
            `).join('');

        }, 500);
    }

    function copyHook(text) {
        navigator.clipboard.writeText(text).then(() => {
            alert("Copied!");
        }).catch(() => {
            alert("Copy failed!");
        });
    }
</script>

</body>
</html> 
